      "targets": [
        {
          "datasource": "mysql",
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "WITH latest_builds AS ( SELECT job_name, MAX(start_time) as max_time FROM _tool_jenkins_builds WHERE job_name IN (${job_id:sqlstring}) GROUP BY job_name ), latest_failed_builds AS ( SELECT b.* FROM _tool_jenkins_builds b INNER JOIN latest_builds lb ON b.job_name = lb.job_name AND b.start_time = lb.max_time WHERE b.result = 'FAILURE' ), numbered_stages AS ( SELECT b.job_name, b.number, b.connection_id, b.start_time, b.full_name, s.name AS stage_name, s.status AS stage_status, s.duration_millis, s.start_time_millis, LPAD(ROW_NUMBER() OVER (PARTITION BY b.full_name ORDER BY s.start_time_millis) - 1, 2, '0') AS stage_num FROM latest_failed_builds b INNER JOIN _tool_jenkins_stages s ON b.full_name = s.build_name ) SELECT ns.job_name AS 'Job', ns.stage_name AS 'Failed Stage', ROUND(ns.duration_millis/1000/60, 1) AS 'Stage Duration (min)', DATE_FORMAT(FROM_UNIXTIME(ns.start_time_millis/1000), '%Y-%m-%d %H:%i') AS 'Failed At', CONCAT(c.endpoint, '/job/', ns.job_name, '/', ns.number, '/artifact/.sh/', ns.stage_num, '-', ns.stage_name, '.log') AS 'Failed Stage Log' FROM numbered_stages ns INNER JOIN _tool_jenkins_connections c ON ns.connection_id = c.id WHERE ns.stage_status = 'FAILED' ORDER BY ns.start_time DESC, ns.start_time_millis ASC LIMIT 50",
          "refId": "A",
          "select": [
