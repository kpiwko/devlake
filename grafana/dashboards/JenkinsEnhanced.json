      "targets": [
        {
          "datasource": "mysql",
          "format": "table",
          "group": [],
          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "WITH latest_builds AS (\n  SELECT job_name, MAX(start_time) as max_time\n  FROM _tool_jenkins_builds\n  WHERE job_name IN (${job_id:sqlstring})\n  GROUP BY job_name\n),\nlatest_failed_builds AS (\n  SELECT b.*\n  FROM _tool_jenkins_builds b\n  INNER JOIN latest_builds lb ON b.job_name = lb.job_name AND b.start_time = lb.max_time\n  WHERE b.result = 'FAILURE'\n)\nSELECT \n  s.name as 'Stage Name',\n  COUNT(*) as 'Failure Count'\nFROM _tool_jenkins_stages s\nINNER JOIN latest_failed_builds b ON s.build_name = b.full_name\nWHERE s.status = 'FAILED'\nGROUP BY s.name\nORDER BY COUNT(*) DESC\nLIMIT 15",
          "refId": "A",
          "select": [
            [
              {
                "params": [
                  "id"
                ],
                "type": "column"
              }
            ]
