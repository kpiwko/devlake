          "metricColumn": "none",
          "rawQuery": true,
          "rawSql": "SELECT b.job_name as 'Job Name', b.number as 'Build #', b.result as 'Result', DATE_FORMAT(b.start_time, '%Y-%m-%d %H:%i') as 'Started', ROUND(b.duration/1000/60, 1) as 'Duration (min)', CONCAT(c.endpoint, '/job/', b.job_name, '/', b.number, '/console') as console_url FROM _tool_jenkins_builds b INNER JOIN _tool_jenkins_connections c ON b.connection_id = c.id INNER JOIN ( SELECT job_name, MAX(start_time) as max_time FROM _tool_jenkins_builds WHERE job_name IN (${job_id:sqlstring}) GROUP BY job_name ) latest ON b.job_name = latest.job_name AND b.start_time = latest.max_time ORDER BY b.start_time DESC",
